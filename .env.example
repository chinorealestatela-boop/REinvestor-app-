# DealRadar environment variables
# Copy to .env.local and fill in as you procure each key. The app runs on
# sample data with NONE of these set; add them to enable live features.

# --- AI (required for CMA generation, remark NLP, report writing) ----------
ANTHROPIC_API_KEY=

# --- Property data (Phase 1) -----------------------------------------------
RENTCAST_API_KEY=

# --- Neighborhood intelligence (Phase 1, mostly free) ----------------------
FBI_CRIME_API_KEY=
GREATSCHOOLS_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- Database / persistence (Phase 1) --------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Notifications (Phase 2) -----------------------------------------------
# Resend: resend.com free tier — powers CMA emails + daily report email
RESEND_API_KEY=
FROM_EMAIL=DealRadar <deals@yourdomain.com>
# Twilio: twilio.com — powers SMS alerts for elite deals + daily SMS summary
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Your contact info for alerts and daily reports
INVESTOR_EMAIL=you@youremail.com
INVESTOR_PHONE=+17025550000

# --- Deep public records (Phase 2, optional) -------------------------------
ATTOM_API_KEY=
